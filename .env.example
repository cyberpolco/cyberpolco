# ─── Database (required) ─────────────────────────────────────────────────
# Neon Postgres connection string — create a free database at neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Admin auth (required) ───────────────────────────────────────────────
ADMIN_EMAIL=admin@cyberpolco.com
# Generate with: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=$2b$10$BYJY2qkuW3cuUBr5OkuZFu0nEgJYvFBrSjD6uqSAoQsd07MF2XrGO
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-random-64-char-hex-string

# ─── Email (optional — falls back to console logging in dev) ────────────
RESEND_API_KEY=
EMAIL_FROM="Cyber PolCo <notifications@cyberpolco.com>"

# ─── File storage for CV uploads (optional — falls back to local disk) ──
BLOB_READ_WRITE_TOKEN=

# ─── CAPTCHA (optional — widget hidden until configured) ────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
